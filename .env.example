# ─── English Quest — environment variables ─────────────────────────────
# Copy this file to `.env.local` for local development.
# The demo login works with NO configuration at all.

# Public Google OAuth Client ID for client-side "Sign in with Google"
# (Google Identity Services). This value is PUBLIC and safe to commit / bake
# into the static build — there is no client secret in this flow.
#
# Create one at https://console.cloud.google.com/apis/credentials
#   → Create credentials → OAuth client ID → Web application
# Add these "Authorized JavaScript origins":
#   http://localhost:3000
#   https://am-piyus.github.io
#
# For GitHub Pages, set this as a repository *variable* named
# NEXT_PUBLIC_GOOGLE_CLIENT_ID (Settings → Secrets and variables → Actions → Variables).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
